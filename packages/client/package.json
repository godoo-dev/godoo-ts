{
  "name": "@godoo-dev/client",
  "version": "0.6.1",
  "description": "Lightweight TypeScript client for Odoo RPC operations",
  "type": "module",
  "license": "LGPL-3.0",
  "author": "Marc Fargas <marc@marcfargas.com>",
  "keywords": [
    "odoo",
    "rpc",
    "client",
    "typescript"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@godoo-dev/testcontainers": "workspace:*",
    "@types/debug": "^4.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/godoo-dev/godoo-ts.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/godoo-dev/godoo-ts/tree/main/packages/client",
  "publishConfig": {
    "access": "public"
  }
}
