{
  "name": "@godoo-dev/testcontainers",
  "version": "0.1.6",
  "description": "Testcontainers module for Odoo development",
  "type": "module",
  "license": "LGPL-3.0",
  "author": "Marc Fargas <marc@marcfargas.com>",
  "keywords": [
    "odoo",
    "testcontainers",
    "testing",
    "integration-testing",
    "docker"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:integration": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@godoo-dev/client": "workspace:*",
    "@testcontainers/postgresql": "^10.13.2",
    "debug": "^4.3.4",
    "dockerode": "^4.0.0",
    "testcontainers": "^10.13.2"
  },
  "peerDependencies": {
    "@godoo-dev/client": "workspace:*"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/dockerode": "^3.3.23"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/godoo-dev/godoo-ts.git",
    "directory": "packages/testcontainers"
  },
  "homepage": "https://github.com/godoo-dev/godoo-ts/tree/main/packages/testcontainers",
  "publishConfig": {
    "access": "public"
  }
}
